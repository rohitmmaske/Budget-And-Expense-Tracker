# ============================================================
# Budget Bloom — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# ----------------------------------------------------------
# DATABASE
# ----------------------------------------------------------
# Leave empty to use SQLite (local dev, no setup required).
# For Supabase, paste your direct connection string below.
#
# Supabase direct connection (port 5432):
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
#
# Supabase pooler connection (port 6543):
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
#
# The app automatically selects the right psycopg driver (v3 or v2).
DATABASE_URL=

# ----------------------------------------------------------
# JWT / SECURITY
# ----------------------------------------------------------
# REQUIRED for production: set a long random string (32+ chars).
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-secret-key

# JWT signing algorithm. HS256 is recommended.
JWT_ALGORITHM=HS256

# Token lifetime in minutes. 1440 = 24 hours.
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ----------------------------------------------------------
# CORS
# ----------------------------------------------------------
# Comma-separated list of allowed origins.
# Use * (default) only for local development.
# For production, set to your frontend domain:
# ALLOWED_ORIGINS=https://yourapp.com,https://www.yourapp.com
ALLOWED_ORIGINS=*
