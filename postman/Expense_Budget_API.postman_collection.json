            "  const items = pm.response.json();",
            "  pm.expect(items).to.be.an('array');",
            "  if (items.length > 0) {",
            "    pm.expect(items[0]).to.have.keys(['category','total']);",
            "  }",
            "});"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/finance/charts/categories", "host": ["{{base_url}}"], "path": ["finance","charts","categories"] }
          }
