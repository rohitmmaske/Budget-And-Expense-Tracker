    {
      "name": "Dashboard & Charts",
      "item": [
        {
          "name": "Summary",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Summary has all required fields', () => {",
            "  const s = pm.response.json();",
            "  ['total_income','total_expense','total_savings','balance_after_expense','available_balance'].forEach(f => {",
            "    pm.expect(s).to.have.property(f);",
            "  });",
            "});",
            "pm.test('Balance = income - expense - savings', () => {",
            "  const s = pm.response.json();",
            "  const expected = (Number(s.total_income) - Number(s.total_expense) - Number(s.total_savings)).toFixed(2);",
            "  pm.expect(Number(s.available_balance).toFixed(2)).to.eql(expected);",
            "});"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/finance/summary", "host": ["{{base_url}}"], "path": ["finance","summary"] }
          }
        },
        {
          "name": "Category Chart",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
